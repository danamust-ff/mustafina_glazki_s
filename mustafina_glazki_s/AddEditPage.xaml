<Page x:Class="mustafina_glazki_s.AddEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:mustafina_glazki_s"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddEditPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
            <TextBlock Text="Наименование" FontSize="15" Height="20" Width="150"></TextBlock>
            <TextBox Text="{Binding Title}" FontSize="15" Height="20" Width="250"></TextBox>
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal">
            <TextBlock Text="Адрес" FontSize="15" Height="20" Width="150"></TextBlock>
            <TextBox Text="{Binding Address}" FontSize="15" Height="20" Width="250"></TextBox>
        </StackPanel>
        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal">
            <TextBlock Text="     ФИО директора" FontSize="15" Height="20" Width="150"></TextBlock>
            <TextBox Text="{Binding DirectorName}" FontSize="15" Height="20" Width="250"></TextBox>
        </StackPanel>
        <StackPanel Grid.Row="3" Orientation="Horizontal" Grid.RowSpan="2"> 
            <TextBlock Text="Логотип" FontSize="15" Height="20" Width="150"></TextBlock>
            <Image Name="LogoImage"  >
                <Image.Source>
                    <Binding Path="AgentPhotoPath" TargetNullValue="image/picture.png"  ></Binding>
                </Image.Source>
            </Image>
        </StackPanel>
        <Button Content="Изменить" Name="ChangePictureBtn" Click="ChangePictureBtn_Click" Grid.Row="6" Grid.Column="0" FontSize="20" Width="175" Height="30" Background="#B175EE" ></Button>
        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
            <TextBlock Text="Тип агента" FontSize="15" Width="150" Height="20"></TextBlock>
            <ComboBox Width="100" Height="30" SelectedIndex="{Binding AgentTypeID}" FontSize="15" Name="ComboTYpe" >
                <Label Content=""></Label>
                <Label Content="МФО"></Label>
                <Label Content="ООО"></Label>
                <Label Content="ЗАО"></Label>
                <Label Content="МКК"></Label>
                <Label Content="ОАО"></Label>
                <Label Content="ПАО"></Label>
            </ComboBox>
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
            <TextBlock Text="Приоритет" FontSize="15" Width="150" Height="20"></TextBlock>
            <TextBox Text="{Binding Priority}" FontSize="15" Height="20" Width="250"></TextBox>
        </StackPanel>
        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
            <TextBlock Text="ИНН" FontSize="15" Width="150" Height="20"></TextBlock>
            <TextBox Text="{Binding INN}" FontSize="15" Height="20" Width="250"></TextBox>
        </StackPanel>
        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
            <TextBlock Text="КПП" FontSize="15" Width="150" Height="20"></TextBlock>
            <TextBox Text="{Binding KPP}" FontSize="15" Height="20" Width="250"></TextBox>
        </StackPanel>
        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
            <TextBlock Text="Email" FontSize="15" Width="150" Height="20"></TextBlock>
            <TextBox Text="{Binding Email}" FontSize="15" Height="20" Width="250"></TextBox>
        </StackPanel>
        <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal">
            <TextBlock Text="Телефон" FontSize="15" Width="150" Height="20"></TextBlock>
            <TextBox Text="{Binding Phone}" FontSize="15" Height="20" Width="250"></TextBox>
        </StackPanel>
        <Button Content="Удалить" Name="DeleteAgent" Click="DeleteAgent_Click" Grid.Row="6" Grid.Column="1" HorizontalAlignment="Left" FontSize="20" Height="30" Width="175" Background="#B175EE" ></Button>
        <Button Content="Сохранить" Name="SaveAgent" Click="SaveAgent_Click" Grid.Row="6" Grid.Column="1" HorizontalAlignment="Right" Height="30" FontSize="20" Width="175" Background="#B175EE" ></Button>
    </Grid>
</Page>
