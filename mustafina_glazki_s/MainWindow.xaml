<Window x:Class="mustafina_glazki_s.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:mustafina_glazki_s"
        mc:Ignorable="d"
        Title="Мустафина" Height="700" Width="1000" FontFamily="Century Gothic" Icon="/image/Глазки-save.ico" >

    <Grid Background="#FFFFE9F9"> 
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <Image Source="/image/Глазки-save.ico" HorizontalAlignment="Left" />
        <TextBlock Text="Агентство" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
        <Frame Name="MainFrame" ContentRendered="MainFrame_ContentRendered" NavigationUIVisibility="Hidden"></Frame>
        <Button Content="Назад" Name="BtnBack" Width="175" Height="30" FontSize="20" Click="BtnBack_Click" HorizontalAlignment="Right" ></Button>

    </Grid>
</Window>
