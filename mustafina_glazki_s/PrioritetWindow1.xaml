<Window x:Class="mustafina_glazki_s.PrioritetWindow1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:mustafina_glazki_s"
        mc:Ignorable="d"
        Title="Изменение приоритета" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Message, RelativeSource={RelativeSource AncestorType=Window}}" 
                   FontSize="14" Margin="0,0,0,20" TextWrapping="Wrap"/>

        <TextBox x:Name="PriorityTextBox" Grid.Row="1" FontSize="16" Height="35" 
                 Margin="0,0,0,20" VerticalContentAlignment="Center"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Изменить" Width="100" Height="35" Margin="0,0,10,0" 
                    Click="OkButton_Click" Background="#B175EE"/>
            <Button Content="Отмена" Width="100" Height="35" Click="CancelButton_Click" 
                    Background="#B175EE"/>
        </StackPanel>
    </Grid>
</Window>
